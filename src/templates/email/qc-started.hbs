<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your piece is in quality check</title>
</head>
<body style="margin: 0; padding: 0; background-color: #F5F5F5; font-family: Arial, sans-serif; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%;">

  <!-- Outer wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #F5F5F5;">
    <tr>
      <td align="center" style="padding: 24px 16px;">

        <!-- Main container -->
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width: 600px; width: 100%; background-color: #FFFFFF; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">

          <!-- Gold Header Bar -->
          <tr>
            <td align="center" style="background-color: #B8860B; padding: 28px 24px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 36px; font-weight: bold; color: #FFFFFF; letter-spacing: 8px;">
                    SBEK
                  </td>
                </tr>
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 11px; color: rgba(255,255,255,0.8); letter-spacing: 3px; padding-top: 6px; text-transform: uppercase;">
                    Fine Indian Jewelry
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Decorative gold line -->
          <tr>
            <td style="background-color: #DAA520; height: 3px; font-size: 0; line-height: 0;">&nbsp;</td>
          </tr>

          <!-- Body Content -->
          <tr>
            <td style="padding: 40px 32px 24px 32px;">

              <!-- Heading & Greeting -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding-bottom: 24px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" style="width: 72px; height: 72px; background-color: #FFF8E7; border: 3px solid #B8860B; border-radius: 50%; font-size: 36px; line-height: 72px; color: #B8860B;">
                          &#128270;
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 24px; color: #B8860B; padding-bottom: 8px;">
                    Quality Check in Progress
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #333333; line-height: 1.6; padding-top: 16px; padding-bottom: 24px;">
                    Dear {{customer_name}},
                  </td>
                </tr>
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7; padding-bottom: 16px;">
                    Great news! Your <strong style="color: #333333;">{{product_name}}</strong> has completed production and is now undergoing our rigorous quality inspection. Our expert team is carefully examining every detail to ensure your piece meets the exacting standards that SBEK is known for.
                  </td>
                </tr>
              </table>

              <!-- Order Reference -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding: 8px 0 24px 0;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #FBF7F0; border-left: 4px solid #B8860B; border-radius: 4px;">
                      <tr>
                        <td style="padding: 18px 24px;">
                          <span style="font-family: Arial, sans-serif; font-size: 14px; color: #888888; text-transform: uppercase; letter-spacing: 1px;">Order ID</span><br />
                          <span style="font-family: Arial, sans-serif; font-size: 16px; color: #333333; font-weight: bold;">{{order_id}}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="border-bottom: 2px solid #F0E6D0; height: 1px; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
              </table>

              <!-- QC Process Section -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Georgia, serif; font-size: 20px; color: #B8860B; padding: 28px 0 16px 0;">
                    What We Check
                  </td>
                </tr>
              </table>

              <!-- QC Items -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #FBF7F0; border-radius: 6px; border: 1px solid #F0E6D0;">
                <tr>
                  <td style="padding: 24px 24px 16px 24px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.8; padding-bottom: 8px;">
                          <span style="color: #B8860B; font-weight: bold;">&#9672;</span>&nbsp;&nbsp;Dimensions and specifications match your order
                        </td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.8; padding-bottom: 8px;">
                          <span style="color: #B8860B; font-weight: bold;">&#9672;</span>&nbsp;&nbsp;Metal finish and polish quality
                        </td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.8; padding-bottom: 8px;">
                          <span style="color: #B8860B; font-weight: bold;">&#9672;</span>&nbsp;&nbsp;Stone setting security and alignment
                        </td>
                      </tr>
                      <tr>
                        <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.8;">
                          <span style="color: #B8860B; font-weight: bold;">&#9672;</span>&nbsp;&nbsp;Overall craftsmanship and packaging
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="border-bottom: 2px solid #F0E6D0; padding-top: 28px; height: 1px; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
              </table>

              <!-- Next Steps -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7; padding-top: 28px; padding-bottom: 16px;">
                    Once your piece passes all quality checks, we will carefully package it and prepare it for shipping. You will receive another update shortly!
                  </td>
                </tr>
              </table>

              <!-- Closing -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-family: Arial, sans-serif; font-size: 16px; color: #555555; line-height: 1.7; padding-top: 12px; padding-bottom: 8px;">
                    With warm regards,<br />
                    <strong style="color: #B8860B;">The SBEK Team</strong>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #1A1A1A; padding: 32px 32px 24px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <!-- Brand -->
                <tr>
                  <td align="center" style="font-family: Georgia, serif; font-size: 24px; color: #B8860B; letter-spacing: 6px; padding-bottom: 16px;">
                    SBEK
                  </td>
                </tr>
                <!-- Contact Info -->
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 13px; color: #999999; line-height: 1.8; padding-bottom: 16px;">
                    Phone: {{support_phone}} &nbsp;|&nbsp; Email: {{support_email}}
                  </td>
                </tr>
                <!-- Social Links -->
                <tr>
                  <td align="center" style="padding-bottom: 20px;">
                    <a href="{{instagram_url}}" style="font-family: Arial, sans-serif; font-size: 13px; color: #B8860B; text-decoration: none; padding: 0 10px;">Instagram</a>
                    <span style="color: #555555;">|</span>
                    <a href="{{facebook_url}}" style="font-family: Arial, sans-serif; font-size: 13px; color: #B8860B; text-decoration: none; padding: 0 10px;">Facebook</a>
                    <span style="color: #555555;">|</span>
                    <a href="{{pinterest_url}}" style="font-family: Arial, sans-serif; font-size: 13px; color: #B8860B; text-decoration: none; padding: 0 10px;">Pinterest</a>
                  </td>
                </tr>
                <!-- Divider -->
                <tr>
                  <td style="border-bottom: 1px solid #333333; height: 1px; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
                <!-- Unsubscribe -->
                <tr>
                  <td align="center" style="font-family: Arial, sans-serif; font-size: 12px; color: #777777; padding-top: 16px;">
                    You received this email because you placed an order with SBEK.<br />
                    <a href="{{unsubscribe_url}}" style="color: #999999; text-decoration: underline;">Unsubscribe</a> from future emails.
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
        <!-- End Main Container -->

      </td>
    </tr>
  </table>
  <!-- End Outer Wrapper -->

</body>
</html>
