# ============================================
# SBEK Automation — Environment Variables
# Copy to .env and fill in your values
# ============================================

# ---------- Server ----------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---------- PostgreSQL ----------
POSTGRES_DB=sbek
POSTGRES_USER=sbek
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://sbek:your_secure_password_here@postgres:5432/sbek

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- WooCommerce ----------
WOO_URL=https://your-store.com
WOO_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxx
WOO_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxx
WOO_WEBHOOK_SECRET=your_webhook_secret_here

# ---------- Google (Sheets + Drive) ----------
GOOGLE_SERVICE_ACCOUNT_EMAIL=sbek-bot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# ---------- WhatsApp Business Cloud API ----------
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
WHATSAPP_API_VERSION=v21.0

# ---------- Email (SMTP) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="SBEK <orders@sbek.com>"

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Gemini / Nano Banana (image generation) ----------
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# ---------- Wati (WhatsApp backup — optional) ----------
WATI_API_KEY=your_wati_api_key
WATI_BASE_URL=https://live-mt-server.wati.io

# ---------- Interakt (WhatsApp backup — optional) ----------
INTERAKT_API_KEY=your_interakt_api_key

# ---------- Postiz ----------
POSTIZ_API_KEY=your_postiz_api_key
POSTIZ_BASE_URL=https://app.postiz.com/api/v1

# ---------- Crawler ----------
CRAWLER_BASE_URL=http://crawler:3001

# ---------- Admin (Bull Board Dashboard) ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# ---------- Brand Config ----------
BRAND_NAME=SBEK
BRAND_PRIMARY_COLOR=#B8860B
BRAND_WEBSITE=https://your-store.com
BRAND_SUPPORT_PHONE=+91XXXXXXXXXX
BRAND_SUPPORT_EMAIL=support@sbek.com
REVIEW_URL=https://your-store.com/reviews
